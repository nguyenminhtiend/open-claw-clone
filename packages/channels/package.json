    "check": "biome check --write src"
  },
  "dependencies": {
    "@oclaw/shared": "workspace:*",
    "discord.js": "^14.18.0",
    "grammy": "^1.36.0",
    "nanoid": "^5.1.6"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.5",
    "vitest": "^3.0.0"
  }
}
