    "@oclaw/shared": "workspace:*",
    "@oclaw/tools": "workspace:*",
    "better-sqlite3": "^11.0.0",
    "glob": "^11.0.0",
    "nanoid": "^5.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0"
  }
