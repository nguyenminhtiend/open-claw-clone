{
  "name": "@oclaw/plugins",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint --write src",
    "format": "biome format --write src",
    "check": "biome check --write src"
  },
  "dependencies": {
    "@oclaw/channels": "workspace:*",
    "@oclaw/config": "workspace:*",
    "@oclaw/memory": "workspace:*",
    "@oclaw/pipeline": "workspace:*",
    "@oclaw/shared": "workspace:*",
    "@oclaw/tools": "workspace:*",
    "jiti": "^2.6.1",
    "json5": "^2.2.3",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.4.5",
    "vitest": "^3.0.0"
  }
}
